# Runtime
NODE_ENV=production
PORT=3000

# App secrets
ADMIN_PASSWORD=change-me
CAMPAIGN_SESSION_SECRET=change-me-with-a-long-random-secret

# Public URL
APP_BASE_URL=https://clubes.example.edu

# Production database
DATABASE_URL=postgresql://clubes:change-me@db:5432/clubes?schema=public

# Local PostgreSQL container defaults for Docker Compose examples
POSTGRES_DB=clubes
POSTGRES_USER=clubes
POSTGRES_PASSWORD=change-me

# Cloudflare Tunnel token for the school-hosted deployment example
CLOUDFLARE_TUNNEL_TOKEN=

# VPS reverse proxy hostname for the Caddy example
SERVER_NAME=clubes.example.edu
